{
  // ── C++ IntelliSense ────────────────────────────────────────────────────────
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
  // Use the compile_commands.json generated by CMake Tools for accurate
  // IntelliSense (include paths, defines, flags).
  "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",
  "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",

  // ── CMake Tools ─────────────────────────────────────────────────────────────
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.generator": "Ninja",
  "cmake.configureArgs": [
    "-DCMAKE_BUILD_TYPE=Release",
    "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
  ],
  "cmake.defaultVariants": {
    "buildType": {
      "default": "release",
      "choices": {
        "debug": {
          "short": "Debug",
          "buildType": "Debug"
        },
        "release": {
          "short": "Release",
          "buildType": "Release"
        }
      }
    }
  },
  // Build the main demo executable by default
  "cmake.defaultBuildTarget": "mgapp",

  // ── Editor ──────────────────────────────────────────────────────────────────
  "editor.formatOnSave": false,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "[cpp]": {
    "editor.tabSize": 2
  },

  // ── File associations ───────────────────────────────────────────────────────
  "files.associations": {
    "*.l": "lex",
    "*.ypp": "yacc",
    "*.h": "cpp",
    "*.hpp": "cpp"
  },

  // ── Search / Explorer exclusions ────────────────────────────────────────────
  "files.exclude": {
    "build/": true,
    "**/*.o": true,
    "**/*.a": true
  },
  "search.exclude": {
    "build/": true,
    "src/gsl/": true
  }
}
