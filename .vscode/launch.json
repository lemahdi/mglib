{
  "version": "0.2.0",
  "configurations": [
    // ── Debug mgapp ───────────────────────────────────────────────────────────
    {
      "name": "Debug mgapp",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/mgapp",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set disassembly flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ],
      // Build a Debug binary before launching
      "preLaunchTask": "CMake: Build mgapp",
      "miDebuggerPath": "/usr/bin/gdb",
      "logging": {
        "engineLogging": false
      }
    },
    // ── Run mgapp (no debugger) ───────────────────────────────────────────────
    {
      "name": "Run mgapp",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/mgapp",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "CMake: Build mgapp"
    }
  ]
}
