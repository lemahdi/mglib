{
  "version": "2.0.0",
  "tasks": [
    // ── Configure ─────────────────────────────────────────────────────────────
    {
      "label": "CMake: Configure (Release)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-B", "build",
        "-G", "Ninja",
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: Configure (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-B", "build",
        "-G", "Ninja",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // ── Build ─────────────────────────────────────────────────────────────────
    {
      "label": "CMake: Build (all)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build", "--parallel"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "CMake: Build mgapp",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build", "--target", "mgapp", "--parallel"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    },

    // ── Smoke test ────────────────────────────────────────────────────────────
    {
      "label": "Run: mgapp (smoke test)",
      "type": "shell",
      // Pipe empty stdin so the interactive cin pause returns immediately.
      "command": "echo \"\" | timeout 10 ./build/mgapp || true",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "dependsOn": "CMake: Build mgapp",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // ── Clean ─────────────────────────────────────────────────────────────────
    {
      "label": "CMake: Clean",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build", "--target", "clean"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
